# AI Brain — USA · config.toml
# Generated by setup.sh. Customize as needed.

[jurisdiction]
country = "USA"
citation_format = "Bluebook"                           # Bluebook for US legal citations
court_hierarchy = "../usa/_court_hierarchy.json"        # path to a JSON map of courts (federal + 50 state)
bar_rules = "../usa/_bar_rules.md"                      # path to bar-rules markdown (state Bar associations)
timezone = "America/New_York"                            # configurable per state, DST-aware

[paths]
statute_corpus = "../usa/_statute_corpus/"
drafting_corpus = "../usa/_drafting_data/"
audit_log_dir = "~/.ailawfirm_usa/audit_logs/"
matter_root = "~/.ailawfirm_usa/matters/"

[llm]
provider = "claude"                                      # v0.1 only supports claude
# In v0.3+: "openai" · "gemini_paid" · "ollama" · "byom"
